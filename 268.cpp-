class Solution {
public:
    int missingNumber(vector<int>& nums) {
        int n = nums.size();
        int ans;
        for (int i = 0; i <= n; i++)
        {
            bool found = false;
            for (int j = 0; j < n; j++)
            {
                if (i == nums[j])
                {
                    found = true;
                    break;
                }
            }
            if (!found)
                ans = i;
        }
        return ans;
    }
};